{
  "mcpServers": {
    "cloudwatch": {
      "command": "uvx",
      "args": ["awslabs.cloudwatch-mcp-server@latest"],
      "env": {
        "AWS_PROFILE": "vignesh-sso-profile",
        "AWS_REGION": "us-east-1"
      }
    },
    "dynamodb": {
      "command": "uvx",
      "args": ["awslabs.dynamodb-mcp-server@latest"],
      "env": {
        "AWS_PROFILE": "vignesh-sso-profile",
        "AWS_REGION": "us-east-1"
      }
    },
    "sqlite": {
      "command": "uvx",
      "args": [
        "mcp-server-sqlite",
        "--db-path",
        "/Users/vignesh/.stock_screener/local_history.db"
      ]
    }
  }
}
